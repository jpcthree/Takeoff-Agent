  "code_requirements": {
    "5": {
      "code_name": "2021 IECC with Denver Amendments",
      "effective_date": "May 1, 2023",
      "exterior_walls": {
        "r_value": "R-20 cavity OR R-13+5ci OR R-0+20ci",
        "description": "Wood frame walls: R-20 cavity insulation, OR R-13 cavity + R-5 continuous insulation, OR R-20 continuous only",
        "notes": "Grade 1 installation required (Denver amendment). No gaps or voids allowed in batt/loose-fill."
      },
      "attic_ceiling": {
        "r_value": "R-60",
        "description": "Flat ceiling with attic above: R-60 blown or batt insulation",
        "notes": "R-49 acceptable if full height insulation extends to wall plate at eaves. Increased from R-49 in prior code."
      },
      "cathedral_ceiling": {
        "r_value": "R-60",
        "description": "Cathedral/vaulted ceiling or roof deck: R-60 total (cavity + continuous)",
        "notes": "Vented: ~R-50 cavity + R-10 rigid = R-60. Unvented: minimum R-20 rigid foam required above deck."
      },
      "basement_walls": {
        "r_value": "R-15ci OR R-19 cavity OR R-13+5ci",
        "description": "Below-grade basement walls: R-15 continuous, OR R-19 cavity, OR R-13 cavity + R-5 continuous",
        "notes": "Interior rigid foam + framed cavity with batt is standard retrofit approach."
      },
      "crawlspace_walls": {
        "r_value": "R-15ci OR R-19 cavity OR R-13+5ci",
        "description": "Crawlspace walls (conditioned/unvented): Same options as basement walls",
        "notes": "Unventilated crawlspace: insulate walls, Class I vapor retarder over exposed earth with 6\" overlaps."
      },
      "rim_joist": {
        "r_value": "R-15 (spray foam) or R-10ci",
        "description": "Rim/band joist: closed-cell spray foam or rigid foam, air sealed",
        "notes": "Must use rigid foam or closed-cell spray foam — NOT fiberglass/mineral wool. Air barrier required on both sides."
      },
      "floors_over_unconditioned": {
        "r_value": "R-38",
        "description": "Floors over unconditioned spaces (garage, vented crawlspace, cantilever): R-38",
        "notes": "Applies to rooms above garages, cantilevers, and floors above ventilated crawlspaces."
      },
      "slab_edge": {
        "r_value": "R-10, 4 ft depth",
        "description": "Slab-on-grade perimeter: R-10 continuous insulation extending 4 feet",
        "notes": "Must extend 4 feet horizontally from perimeter or to centerline of floor."
      },
      "air_sealing": {
        "requirement": "3 ACH50 maximum",
        "description": "Blower door test required: 3 air changes per hour at 50 Pascals",
        "notes": "Denver amendments strengthen air sealing requirements beyond base IECC."
      },
      "fenestration": {
        "u_factor": "0.27",
        "shgc": "0.40",
        "description": "Windows: U-0.27 max (U-0.25 if glazing >15% of floor area). SHGC 0.40 max.",
        "notes": "Skylights: U-0.45 max."
      },
      "renovation_notes": [
        "Additions must meet full new construction standards.",
        "If wall/ceiling cavities are exposed during renovation, they must be filled with insulation.",
        "Roof replacements cannot reduce existing R-value.",
        "Historic buildings may be exempt with qualified professional documentation.",
        "UA Trade-off Path available: allows trading values between assemblies."
      ]
    },
