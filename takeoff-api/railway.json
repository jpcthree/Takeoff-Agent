{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "dockerfilePath": "takeoff-api/Dockerfile",
    "buildContext": "."
  },
  "deploy": {
    "startCommand": "cd /app/takeoff-api && uvicorn main:app --host 0.0.0.0 --port 8000",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
